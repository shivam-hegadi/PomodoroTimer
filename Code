void update_ui()
{
    unsigned int mins = remainingSeconds / 60;
    unsigned int secs = remainingSeconds % 60;
    char buf[6];
    sprintf(buf, "%02d:%02d", mins, secs);
    lv_label_set_text(time_label, buf);

    char stats_txt[30];
    sprintf(stats_txt, "Sessions: %ld", sessionsCompleted);
    lv_label_set_text(stats_label, stats_txt);
}

void setup()
{
    Serial.begin(115200);
    delay(400);

    tft.init();
    tft.setRotation(0);
    tft.fillScreen(TFT_BLACK);
    pinMode(TFT_BL_PIN, OUTPUT);
    digitalWrite(TFT_BL_PIN, HIGH);

    touchSPI.begin(TOUCH_CLK, TOUCH_MISO, TOUCH_MOSI, TOUCH_CS_PIN);
    touch.begin(touchSPI);
    touch.setRotation(0);

    lv_init();

    static lv_color_t buf[SCR_W * 10];
    disp = lv_display_create(SCR_W, SCR_H);
    lv_display_set_flush_cb(disp, disp_flush);
    lv_display_set_buffers(disp, buf, NULL, sizeof(buf), LV_DISPLAY_RENDER_MODE_PARTIAL);

    indev = lv_indev_create();
    lv_indev_set_type(indev, LV_INDEV_TYPE_POINTER);
    lv_indev_set_read_cb(indev, lvgl_read_cb);

    create_ui();
    update_ui();

    touchReleasedMs = millis();
}

void loop()
{
    handleTouchEvent();
    lv_tick_inc(5);
    lv_timer_handler();
    update_screen_flash();

    if (currentState == WORKING || currentState == BREAKING) {
        unsigned long now = millis();
        if (now - lastTick >= 1000) {
            lastTick = now;
            if (remainingSeconds > 0) {
                remainingSeconds--;
                update_ui();
                if (notificationsEnabled && remainingSeconds == 10) {
                    lv_obj_set_style_bg_color(lv_screen_active(), lv_color_hex(0xFF4500), 0);
                }
                if (notificationsEnabled && remainingSeconds <= 10 && remainingSeconds > 0) {
                    if (remainingSeconds % 2 == 0) {
                        lv_obj_set_style_bg_color(lv_screen_active(), lv_color_hex(0xFF4500), 0);
                    } else {
                        lv_obj_set_style_bg_color(lv_screen_active(), lv_color_hex(0x0B0F14), 0);
                    }
                }
            } else {
                if (currentState == WORKING) {
                    sessionsCompleted++;
                    sessionsBeforeLongBreak--;
                    screen_flash();
                    if (autoStartBreak) {
                        if (sessionsBeforeLongBreak == 0) {
                            remainingSeconds = LONG_BREAK_TIME;
                            sessionsBeforeLongBreak = sessionsUntilLongBreak;
                            currentState = BREAKING;
                            lv_label_set_text(state_label, "LONG BREAK");
                        } else {
                            remainingSeconds = BREAK_TIME;
                            currentState = BREAKING;
                            lv_label_set_text(state_label, "BREAK");
                        }
                        lv_label_set_text(action_btn_label, "Pause");
                    } else {
                        remainingSeconds = WORK_TIME;
                        currentState = IDLE;
                        lv_label_set_text(state_label, "IDLE");
                        lv_label_set_text(action_btn_label, "Start");
                    }
                } else {
                    screen_flash();
                    remainingSeconds = WORK_TIME;
                    currentState = IDLE;
                    lv_label_set_text(state_label, "IDLE");
                    lv_label_set_text(action_btn_label, "Start");
                }
                update_ui();
                lastTick = millis();
            }
        }
    }

    delay(5);
}
