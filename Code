static unsigned long touchReleasedMs = 0;
#define TOUCH_DEBOUNCE_MS 200
#define LONG_PRESS_MS 800

unsigned long sessionsCompleted = 0;
unsigned long timerFinishedMs = 0;
bool flashingScreen = false;

static void disp_flush(lv_display_t *disp, const lv_area_t *area, uint8_t *px_map)
{
    uint32_t w = lv_area_get_width(area);
    uint32_t h = lv_area_get_height(area);
    tft.startWrite();
    tft.setAddrWindow(area->x1, area->y1, w, h);
    tft.pushColors((uint16_t *)px_map, w * h, true);
    tft.endWrite();
    lv_display_flush_ready(disp);
}

static void lvgl_read_cb(lv_indev_t*, lv_indev_data_t* data)
{
    if (touchPhysical) {
        data->point.x = touchX;
        data->point.y = touchY;
        data->state   = LV_INDEV_STATE_PRESSED;
    } else {
        data->state = LV_INDEV_STATE_RELEASED;
    }
}

void handleTouchEvent()
{
    bool hw = touch.tirqTouched() && touch.touched();

    if (hw && !touchPhysical) {
        if (millis() - touchReleasedMs >= TOUCH_DEBOUNCE_MS) {
            TS_Point p = touch.getPoint();
            touchX = constrain(map(p.x, TS_MINX, TS_MAXX, 0, SCR_W), 0, SCR_W - 1);
            touchY = constrain(map(p.y, TS_MINY, TS_MAXY, 0, SCR_H), 0, SCR_H - 1);
            touchPressStart = millis();
        }
        touchPhysical = true;
    } else if (!hw && touchPhysical) {
        if (touchPressStart > 0) {
            unsigned long pressDuration = millis() - touchPressStart;
            if (pressDuration > LONG_PRESS_MS && touchX > 60 && touchX < 180 && touchY > 100 && touchY < 220 && settings_modal == NULL) {
                open_settings_menu();
            }
            touchPressStart = 0;
        }
        touchPhysical = false;
        touchReleasedMs = millis();
    }
}

void screen_flash()
{
    flashingScreen = true;
    timerFinishedMs = millis();
}

void update_screen_flash()
{
    if (flashingScreen) {
        unsigned long elapsed = millis() - timerFinishedMs;
        if (elapsed < 400) {
            lv_obj_t *scr = lv_screen_active();
            if ((elapsed / 100) % 2 == 0) {
                lv_obj_set_style_bg_color(scr, lv_color_hex(0xFFFFFF), 0);
            } else {
                lv_obj_set_style_bg_color(scr, lv_color_hex(0x0B0F14), 0);
            }
        } else {
            flashingScreen = false;
            lv_obj_set_style_bg_color(lv_screen_active(), lv_color_hex(0x0B0F14), 0);
        }
    }
}

void close_settings_menu()
{
    if (settings_modal != NULL) {
        lv_obj_t *scr = lv_screen_active();
        lv_obj_clean(scr);
        lv_obj_set_style_bg_color(scr, lv_color_hex(0x0B0F14), 0);
        lv_obj_set_style_bg_opa(scr, LV_OPA_COVER, 0);
        create_ui();
        update_ui();
        settings_modal = NULL;
    }
}

static void work_time_plus_event(lv_event_t *e)
{
    WORK_TIME += 60;
    lv_obj_t *parent = lv_obj_get_parent((lv_obj_t *)lv_event_get_target(e));
    lv_obj_t *work_label = lv_obj_get_child(parent, 1);
    char work_txt[20];
    sprintf(work_txt, "Work: %ldm", WORK_TIME / 60);
    lv_label_set_text(work_label, work_txt);
    if (currentState == IDLE) {
        remainingSeconds = WORK_TIME;
        update_ui();
    }
}

static void work_time_minus_event(lv_event_t *e)
{
    if (WORK_TIME > 60) WORK_TIME -= 60;
