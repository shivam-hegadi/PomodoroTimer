#include <TFT_eSPI.h>
#include <SPI.h>
#include <XPT2046_Touchscreen.h>

#define TFT_BL_PIN    21
#define TOUCH_MOSI    32
#define TOUCH_MISO    39
#define TOUCH_CLK     25
#define TOUCH_CS_PIN  33
#define TOUCH_IRQ     36

#define TS_MINX  200
#define TS_MAXX  3800
#define TS_MINY  300
#define TS_MAXY  3700

#define SCR_W  240
#define SCR_H  320

#define TOUCH_DEBOUNCE_MS  200

TFT_eSPI tft = TFT_eSPI();
SPIClass touchSPI(HSPI);
XPT2046_Touchscreen touch(TOUCH_CS_PIN, TOUCH_IRQ);

const unsigned long WORK_TIME  = 25 * 60;
const unsigned long BREAK_TIME =  5 * 60;

enum State { IDLE, WORKING, BREAKING, PAUSED };
State currentState   = IDLE;
State lastDisplayedState = IDLE;
unsigned long targetTime       = WORK_TIME;
unsigned long remainingSeconds = WORK_TIME;
unsigned long lastDisplayedSeconds = WORK_TIME;
unsigned long lastTick         = 0;

#define BTN_START_X  20
#define BTN_START_Y  200
#define BTN_START_W  200
#define BTN_START_H  50

#define BTN_RESET_X  20
#define BTN_RESET_Y  270
#define BTN_RESET_W  200
#define BTN_RESET_H  50

static bool          touchPhysical    = false;
static bool          touchConsumed    = false;
static int           touchX           = 0;
static int           touchY           = 0;
static unsigned long touchReleasedMs  = 0;

void drawCenteredText(int x, int y, const char* text, uint16_t color, int size) {
  tft.setTextSize(size);
  tft.setTextColor(color, TFT_BLACK);
  tft.setTextDatum(MC_DATUM);
  tft.drawString(text, x, y);
}

void drawInitialScreen() {
  tft.fillScreen(TFT_BLACK);
  
  drawCenteredText(120, 30, "Pomodoro", TFT_CYAN, 3);

  tft.fillRoundRect(BTN_START_X, BTN_START_Y, BTN_START_W, BTN_START_H, 10, TFT_DARKGREEN);
  drawCenteredText(120, 225, "Start", TFT_WHITE, 2);

  tft.fillRoundRect(BTN_RESET_X, BTN_RESET_Y, BTN_RESET_W, BTN_RESET_H, 10, TFT_MAROON);
  drawCenteredText(120, 295, "Reset", TFT_WHITE, 2);
}

void updateDisplay() {
  bool stateChanged = (currentState != lastDisplayedState);
  bool timeChanged = (remainingSeconds != lastDisplayedSeconds);

  if (!stateChanged && !timeChanged) return;

  lastDisplayedState = currentState;
  lastDisplayedSeconds = remainingSeconds;

  tft.fillRect(0, 75, 240, 20, TFT_BLACK);
  const char* stateStr;
  switch (currentState) {
    case IDLE:     stateStr = "IDLE";   break;
    case WORKING:  stateStr = "WORK";   break;
    case BREAKING: stateStr = "BREAK";  break;
    case PAUSED:   stateStr = "PAUSED"; break;
    default:       stateStr = "---";    break;
  }
  drawCenteredText(120, 85, stateStr, TFT_WHITE, 2);

  tft.fillRect(0, 115, 240, 75, TFT_BLACK);
  unsigned int mins = remainingSeconds / 60;
  unsigned int secs = remainingSeconds % 60;
  char buf[6];
  sprintf(buf, "%02d:%02d", mins, secs);
  tft.setTextSize(7);
  tft.setTextColor(TFT_YELLOW, TFT_BLACK);
  tft.setTextDatum(MC_DATUM);
  tft.drawString(buf, 120, 150);

  if (stateChanged) {
    tft.fillRoundRect(BTN_START_X, BTN_START_Y, BTN_START_W, BTN_START_H, 10, TFT_DARKGREEN);
    if (currentState == WORKING || currentState == BREAKING)
      drawCenteredText(120, 225, "Pause", TFT_WHITE, 2);
    else
      drawCenteredText(120, 225, "Start", TFT_WHITE, 2);
  }
}

bool insideButton(int x, int y, int bx, int by, int bw, int bh) {
  return (x >= bx && x < bx + bw && y >= by && y < by + bh);
}

void startTimer() {
  if (currentState == IDLE) {
    remainingSeconds = WORK_TIME;
    targetTime       = WORK_TIME;
    currentState     = WORKING;
    lastTick         = millis();
  } else if (currentState == WORKING || currentState == BREAKING) {
    currentState = PAUSED;
  } else if (currentState == PAUSED) {
    currentState = (remainingSeconds == targetTime) ? WORKING : BREAKING;
    lastTick     = millis();
  }
  updateDisplay();
}

void resetTimer() {
  currentState     = IDLE;
  remainingSeconds = WORK_TIME;
  targetTime       = WORK_TIME;
  updateDisplay();
}

void handleTouchEvent() {
  bool hw = touch.tirqTouched() && touch.touched();

  if (hw && !touchPhysical) {
    if (millis() - touchReleasedMs >= TOUCH_DEBOUNCE_MS) {
      TS_Point p = touch.getPoint();
      touchX = constrain(map(p.x, TS_MINX, TS_MAXX, 0, SCR_W), 0, SCR_W - 1);
      touchY = constrain(map(p.y, TS_MINY, TS_MAXY, 0, SCR_H), 0, SCR_H - 1);
      touchConsumed = false;

      Serial.printf("Touch: raw(%d,%d) -> screen(%d,%d)\n", p.x, p.y, touchX, touchY);

      if (!touchConsumed && insideButton(touchX, touchY, BTN_START_X, BTN_START_Y, BTN_START_W, BTN_START_H)) {
        Serial.println(">> START/PAUSE");
        touchConsumed = true;
        startTimer();
      } else if (!touchConsumed && insideButton(touchX, touchY, BTN_RESET_X, BTN_RESET_Y, BTN_RESET_W, BTN_RESET_H)) {
        Serial.println(">> RESET");
        touchConsumed = true;
        resetTimer();
      }
    }
    touchPhysical = true;

  } else if (!hw && touchPhysical) {
    touchPhysical   = false;
    touchConsumed   = false;
    touchReleasedMs = millis();
  }
}

void setup() {
  Serial.begin(115200);
  delay(400);
  Serial.println("\nPomodoro Timer starting (Portrait)...");

  tft.init();
  tft.setRotation(0);

  touchSPI.begin(TOUCH_CLK, TOUCH_MISO, TOUCH_MOSI, TOUCH_CS_PIN);
  touch.begin(touchSPI);
  touch.setRotation(0);

  remainingSeconds = WORK_TIME;
  targetTime       = WORK_TIME;
  currentState     = IDLE;
  lastDisplayedState = IDLE;
  lastDisplayedSeconds = WORK_TIME;
  touchReleasedMs  = millis();

  drawInitialScreen();
  Serial.println("Ready (Portrait). Buttons: Start(20,200,200x50) Reset(20,270,200x50)");
}

void loop() {
  handleTouchEvent();

  if (currentState == WORKING || currentState == BREAKING) {
    unsigned long now = millis();
    if (now - lastTick >= 1000) {
      lastTick = now;
      if (remainingSeconds > 0) {
        remainingSeconds--;
        updateDisplay();
      } else {
        if (currentState == WORKING) {
          remainingSeconds = BREAK_TIME;
          targetTime       = BREAK_TIME;
          currentState     = BREAKING;
          Serial.println("Work done, break starting");
        } else {
          remainingSeconds = WORK_TIME;
          targetTime       = WORK_TIME;
          currentState     = IDLE;
          Serial.println("Break done, returning to IDLE");
        }
        updateDisplay();
        lastTick = millis();
      }
    }
  }

  delay(5);
}
