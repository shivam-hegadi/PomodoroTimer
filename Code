#define TOUCH_MISO    39
#define TOUCH_CLK     25
#define TOUCH_CS_PIN  33
#define TOUCH_IRQ     36

#define TS_MINX  200
#define TS_MAXX  3800
#define TS_MINY  300
#define TS_MAXY  3700

#define SCR_W  240
#define SCR_H  320

unsigned long WORK_TIME  = 25 * 60;
