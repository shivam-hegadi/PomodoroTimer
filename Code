#include <lvgl.h>
#include <TFT_eSPI.h>
#include <SPI.h>
#include <XPT2046_Touchscreen.h>

#define TFT_BL_PIN    21
#define TOUCH_MOSI    32
#define TOUCH_MISO    39
#define TOUCH_CLK     25
#define TOUCH_CS_PIN  33
#define TOUCH_IRQ     36

#define TS_MINX  200
#define TS_MAXX  3800
#define TS_MINY  300
#define TS_MAXY  3700

#define SCR_W  240
#define SCR_H  320

const unsigned long WORK_TIME  = 25 * 60;
const unsigned long BREAK_TIME =  5 * 60;

TFT_eSPI tft = TFT_eSPI();
SPIClass touchSPI(HSPI);
XPT2046_Touchscreen touch(TOUCH_CS_PIN, TOUCH_IRQ);

static lv_display_t *disp;
static lv_indev_t   *indev;
static lv_timer_t   *timer_obj;

enum State { IDLE, WORKING, BREAKING, PAUSED };
State currentState   = IDLE;
unsigned long targetTime       = WORK_TIME;
unsigned long remainingSeconds = WORK_TIME;
unsigned long lastTick         = 0;

lv_obj_t *state_label;
lv_obj_t *time_label;
lv_obj_t *action_btn;
lv_obj_t *reset_btn;

void lv_timer_callback(lv_timer_t *t);
void update_ui();

static void disp_flush(lv_display_t *disp, const lv_area_t *area, uint8_t *px_map)
{
    uint32_t w = lv_area_get_width(area);
    uint32_t h = lv_area_get_height(area);

    tft.startWrite();
    tft.setAddrWindow(area->x1, area->y1, w, h);
    tft.pushColors((uint16_t *)px_map, w * h, true);
    tft.endWrite();

    lv_display_flush_ready(disp);
}

static void touch_read(lv_indev_t *indev, lv_indev_data_t *data)
{
    static uint32_t last_touch_ms = 0;

    if (touch.tirqTouched() && touch.touched()) {
        TS_Point p = touch.getPoint();
        int16_t x = constrain(map(p.x, TS_MINX, TS_MAXX, 0, SCR_W), 0, SCR_W - 1);
        int16_t y = constrain(map(p.y, TS_MINY, TS_MAXY, 0, SCR_H), 0, SCR_H - 1);
        data->point.x = x;
        data->point.y = y;
        data->state   = LV_INDEV_STATE_PRESSED;
        last_touch_ms = millis();
    } else {
        if (millis() - last_touch_ms > 50) {
            data->state = LV_INDEV_STATE_RELEASED;
        } else {
            data->state = LV_INDEV_STATE_PRESSED;
        }
    }
}

static void action_btn_event(lv_event_t *e)
{
    lv_event_code_t code = lv_event_get_code(e);
    if (code == LV_EVENT_CLICKED) {
        if (currentState == IDLE) {
            remainingSeconds = WORK_TIME;
            currentState = WORKING;
            lastTick = millis();
            lv_label_set_text(state_label, "WORK");
            lv_label_set_text(action_btn, "Pause");
        } else if (currentState == WORKING || currentState == BREAKING) {
            currentState = PAUSED;
            lv_label_set_text(state_label, "PAUSED");
            lv_label_set_text(action_btn, "Start");
        } else if (currentState == PAUSED) {
            if (remainingSeconds == WORK_TIME) currentState = WORKING;
            else currentState = BREAKING;
            lastTick = millis();
            lv_label_set_text(state_label, (currentState == WORKING) ? "WORK" : "BREAK");
            lv_label_set_text(action_btn, "Pause");
        }
        update_ui();
    }
}

static void reset_btn_event(lv_event_t *e)
{
    lv_event_code_t code = lv_event_get_code(e);
    if (code == LV_EVENT_CLICKED) {
        currentState = IDLE;
        remainingSeconds = WORK_TIME;
        lv_label_set_text(state_label, "IDLE");
        lv_label_set_text(action_btn, "Start");
        update_ui();
    }
}

void create_ui()
{
    lv_obj_t *scr = lv_screen_active();

    state_label = lv_label_create(scr);
    lv_label_set_text(state_label, "IDLE");
    lv_obj_set_style_text_color(state_label, lv_color_white(), 0);
    lv_obj_set_style_text_font(state_label, &lv_font_montserrat_20, 0);
    lv_obj_align(state_label, LV_ALIGN_TOP_MID, 0, 20);

    time_label = lv_label_create(scr);
    lv_label_set_text(time_label, "25:00");
    lv_obj_set_style_text_color(time_label, lv_color_hex(0xFFD700), 0);
    lv_obj_set_style_text_font(time_label, &lv_font_montserrat_48, 0);
    lv_obj_align(time_label, LV_ALIGN_CENTER, 0, -20);

    action_btn = lv_btn_create(scr);
    lv_obj_set_size(action_btn, 200, 50);
    lv_obj_align(action_btn, LV_ALIGN_BOTTOM_MID, 0, -70);
    lv_obj_set_style_bg_color(action_btn, lv_color_hex(0x2E8B57), 0);
    lv_obj_add_event_cb(action_btn, action_btn_event, LV_EVENT_CLICKED, NULL);
    lv_obj_t *act_label = lv_label_create(action_btn);
    lv_label_set_text(act_label, "Start");
    lv_obj_center(act_label);

    reset_btn = lv_btn_create(scr);
    lv_obj_set_size(reset_btn, 200, 50);
    lv_obj_align(reset_btn, LV_ALIGN_BOTTOM_MID, 0, -10);
    lv_obj_set_style_bg_color(reset_btn, lv_color_hex(0x800000), 0);
    lv_obj_add_event_cb(reset_btn, reset_btn_event, LV_EVENT_CLICKED, NULL);
    lv_obj_t *rst_label = lv_label_create(reset_btn);
    lv_label_set_text(rst_label, "Reset");
    lv_obj_center(rst_label);
}

void update_ui()
{
    unsigned int mins = remainingSeconds / 60;
    unsigned int secs = remainingSeconds % 60;
    char buf[6];
    sprintf(buf, "%02d:%02d", mins, secs);
    lv_label_set_text(time_label, buf);
}

void lv_timer_callback(lv_timer_t *t)
{
    if (currentState == WORKING || currentState == BREAKING) {
        unsigned long now = millis();
        if (now - lastTick >= 1000) {
            lastTick = now;
            if (remainingSeconds > 0) {
                remainingSeconds--;
                update_ui();
            } else {
                if (currentState == WORKING) {
                    remainingSeconds = BREAK_TIME;
                    currentState = BREAKING;
                    lv_label_set_text(state_label, "BREAK");
                    lv_label_set_text(action_btn, "Pause");
                } else {
                    remainingSeconds = WORK_TIME;
                    currentState = IDLE;
                    lv_label_set_text(state_label, "IDLE");
                    lv_label_set_text(action_btn, "Start");
                }
                update_ui();
                lastTick = millis();
            }
        }
    }
}

void setup()
{
    Serial.begin(115200);
    delay(400);

    tft.init();
    tft.setRotation(0);
    tft.fillScreen(TFT_BLACK);
    pinMode(TFT_BL_PIN, OUTPUT);
    digitalWrite(TFT_BL_PIN, HIGH);

    touchSPI.begin(TOUCH_CLK, TOUCH_MISO, TOUCH_MOSI, TOUCH_CS_PIN);
    touch.begin(touchSPI);
    touch.setRotation(0);

    lv_init();

    static lv_color_t buf[SCR_W * 10];
    disp = lv_display_create(SCR_W, SCR_H);
    lv_display_set_flush_cb(disp, disp_flush);
    lv_display_set_buffers(disp, buf, NULL, sizeof(buf), LV_DISPLAY_RENDER_MODE_PARTIAL);

    indev = lv_indev_create();
    lv_indev_set_type(indev, LV_INDEV_TYPE_POINTER);
    lv_indev_set_read_cb(indev, touch_read);

    create_ui();

    timer_obj = lv_timer_create(lv_timer_callback, 100, NULL);

    update_ui();
    lv_label_set_text(state_label, "IDLE");
}

void loop()
{
    lv_timer_handler();
    delay(5);
}
